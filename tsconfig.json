{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "@repo/core": ["packages/core/src"],
      "@repo/worker": ["packages/worker/src"],
      "@repo/db": ["packages/db/src"],
      "@repo/provider": ["packages/provider/src"],
      "@repo/shared": ["packages/shared/src"]
    }
  }
}
